# Application Settings
APP_NAME=HealHub - AI Healthcare Platform
APP_VERSION=1.0.0
DEBUG=False
API_V1_STR=/api/v1

# Database Configuration
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=healhub

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-12345!@#$%^
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SENDER_EMAIL=noreply@healhub.com
SENDER_NAME=HealHub Support

# Google Meet Configuration
GOOGLE_MEET_LINK=https://meet.google.com/abc-defg-hij

# Frontend Configuration
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Admin Configuration
ADMIN_EMAIL=admin@healhub.com
ADMIN_PASSWORD=AdminPassword123!
ADMIN_USERNAME=admin

# Security Configuration
ALLOWED_HOSTS=*
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "http://localhost:8000"]

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
